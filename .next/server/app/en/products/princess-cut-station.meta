{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/products/layout,_N_T_/[locale]/products/[slug]/layout,_N_T_/[locale]/products/[slug]/page,_N_T_/en/products/princess-cut-station"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/products/$d$slug/__PAGE__",
    "/$d$locale/products/$d$slug",
    "/$d$locale/products",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}